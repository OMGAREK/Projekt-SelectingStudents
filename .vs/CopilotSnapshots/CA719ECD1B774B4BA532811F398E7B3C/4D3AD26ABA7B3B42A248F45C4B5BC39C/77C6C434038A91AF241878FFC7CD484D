using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.Linq;
using System.Windows.Input;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using TheSystemOfSelectingAPTA.Models;
using TheSystemOfSelectingAPTA.Services;

namespace TheSystemOfSelectingAPTA.ViewModels
{
 public class RaffleModel
 {
 public string ClassName { get; set; }
 public List<Student> Students { get; set; } = new List<Student>();
 }

 public class RaffleViewModel : INotifyPropertyChanged
 {
 private readonly ClassService _service = new ClassService();
 private readonly Random _rng = new Random();

 private IList<RaffleModel> _classes = new List<RaffleModel>();
 public IList<RaffleModel> Classes
 {
 get => _classes;
 set { if (_classes != value) { _classes = value; OnPropertyChanged(); } }
 }

 private RaffleModel _selectedClass;
 public RaffleModel SelectedClass
 {
 get => _selectedClass;
 set { if (_selectedClass == value) return; _selectedClass = value; OnPropertyChanged(); }
 }

 private string _result;
 public string Result
 {
 get => _result;
 set { if (_result != value) { _result = value; OnPropertyChanged(); } }
 }

 public ICommand DrawCommand { get; }

 public RaffleViewModel()
 {
 DrawCommand = new Command(Draw);
 LoadClasses();
 }

 private void LoadClasses()
 {
 IList<string> files = new List<string>(_service.GetClassFiles());
 List<RaffleModel> models = new List<RaffleModel>();
 foreach (string f in files)
 {
 RaffleModel rm = new RaffleModel { ClassName = f };
 rm.Students = _service.LoadClass(f);
 models.Add(rm);
 }
 Classes = models;
 if (Classes.Count >0)
 SelectedClass = Classes[0];
 }

 private void Draw()
 {
 if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.ClassName)) return;
 List<Student> students = SelectedClass.Students.Where(s => s.IsPresent).ToList();
 if (students.Count ==0)
 {
 Result = "No students available";
 return;
 }
 int idx = _rng.Next(students.Count);
 Result = students[idx].Name;
 }

 public event PropertyChangedEventHandler PropertyChanged;
 protected void OnPropertyChanged([CallerMemberName] string propertyName = "")
 {
 PropertyChangedEventHandler handler = PropertyChanged;
 if (handler != null)
 {
 handler(this, new PropertyChangedEventArgs(propertyName));
 }
 }
 }
}
