using System;
using System.Linq;
using System.Collections.ObjectModel;
using System.Collections.Generic;
using TheSystemOfSelectingAPTA.Models;
using TheSystemOfSelectingAPTA.Services;

namespace TheSystemOfSelectingAPTA.Views
{
 public partial class ClassPage : ContentPage
 {
 private readonly ClassService _service = new ClassService();
 private ObservableCollection<Student> Students = new ObservableCollection<Student>();
 public ClassPage()
 {
 InitializeComponent();
 StudentsView.ItemsSource = Students;
 LoadClasses();
 ClassPicker.SelectedIndexChanged += (s,e) => LoadSelectedClass();
 }

 void LoadClasses()
 {
 var files = _service.GetClassFiles().ToList();
 ClassPicker.ItemsSource = files;
 if (files.Any())
 {
 ClassPicker.SelectedIndex =0;
 LoadSelectedClass();
 }
 }

 void LoadSelectedClass()
 {
 var name = ClassPicker.SelectedItem as string;
 if (string.IsNullOrEmpty(name)) return;
 Students.Clear();
 foreach (var s in _service.LoadClass(name)) Students.Add(s);
 }

 void OnAddClicked(object sender, EventArgs e)
 {
 if (string.IsNullOrWhiteSpace(NewStudentEntry.Text)) return;
 Students.Add(new Student { Name = NewStudentEntry.Text });
 NewStudentEntry.Text = string.Empty;
 }

 void OnSaveClicked(object sender, EventArgs e)
 {
 var name = ClassPicker.SelectedItem as string;
 if (string.IsNullOrEmpty(name)) return;
 _service.SaveClass(name, Students);
 DisplayAlert("Saved","Class saved","OK");
 }

 void OnDeleteClicked(object sender, EventArgs e)
 {
 var name = ClassPicker.SelectedItem as string;
 if (string.IsNullOrEmpty(name)) return;
 _service.DeleteClass(name);
 LoadClasses();
 }

 void OnNewClassClicked(object sender, EventArgs e)
 {
 if (string.IsNullOrWhiteSpace(ClassNameEntry.Text)) return;
 var name = ClassNameEntry.Text.Trim();
 // create empty class
 _service.SaveClass(name, new List<Student>());
 LoadClasses();
 ClassPicker.SelectedItem = name;
 ClassNameEntry.Text = string.Empty;
 }
 }
}
