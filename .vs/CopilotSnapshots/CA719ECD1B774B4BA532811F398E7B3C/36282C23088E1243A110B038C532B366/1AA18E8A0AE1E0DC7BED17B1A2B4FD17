<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 xmlns:models="clr-namespace:TheSystemOfSelectingAPTA.Models"
 x:Class="TheSystemOfSelectingAPTA.Views.ClassPage"
 Title="Class">

 <VerticalStackLayout Padding="20" Spacing="12">
 <Picker x:Name="ClassPicker" Title="Select Class" />
 <Entry x:Name="NewStudentEntry" Placeholder="New student name" />
 <Button Text="Add" Clicked="OnAddClicked" />
 <CollectionView x:Name="StudentsView" SelectionMode="None">
 <CollectionView.ItemTemplate>
 <DataTemplate>
 <Grid ColumnDefinitions="*,Auto" Padding="4">
 <Label Text="{Binding Name}" VerticalOptions="Center" />
 <CheckBox IsChecked="{Binding IsPresent}" />
 </Grid>
 </DataTemplate>
 </CollectionView.ItemTemplate>
 </CollectionView>
 <Button Text="Save" Clicked="OnSaveClicked" />
 <Button Text="Delete Class" Clicked="OnDeleteClicked" />
 </VerticalStackLayout>

</ContentPage>