<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 x:Class="TheSystemOfSelectingAPTA.Views.StudentView">

    <Grid ColumnDefinitions="*,Auto" Padding="4">
        <Entry Text="{Binding Name}" Placeholder="Student name" />
        <CheckBox Grid.Column="1" IsChecked="{Binding IsPresent}" VerticalOptions="Center" />
    </Grid>

</ContentView>