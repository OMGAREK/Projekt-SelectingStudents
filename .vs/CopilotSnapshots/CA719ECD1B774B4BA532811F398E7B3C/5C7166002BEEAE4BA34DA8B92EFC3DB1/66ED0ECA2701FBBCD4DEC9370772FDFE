<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 xmlns:vm="clr-namespace:TheSystemOfSelectingAPTA.ViewModels"
 x:Class="TheSystemOfSelectingAPTA.Views.ClassPage"
 Title="Class">

	<ContentPage.BindingContext>
		<vm:ClassViewModel />
	</ContentPage.BindingContext>

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="16">
			<Label Text="System losowania - single page" Style="{StaticResource Headline}" />

			<Frame>
				<VerticalStackLayout Spacing="8">
					<Label Text="Manage Classes" Style="{StaticResource SubHeadline}" />
					<HorizontalStackLayout Spacing="8">
						<Entry Text="{Binding NewClassName}" Placeholder="Class name (e.g.1A)" HorizontalOptions="FillAndExpand" />
						<Button Text="New Class" Clicked="OnNewClassClicked" />
					</HorizontalStackLayout>

					<Picker ItemsSource="{Binding Classes}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedClass}" />
					<HorizontalStackLayout Spacing="8">
						<Entry Text="{Binding NewStudentName}" Placeholder="New student name" HorizontalOptions="FillAndExpand" />
						<Button Text="Add" Clicked="OnAddClicked" />
					</HorizontalStackLayout>
					<CollectionView ItemsSource="{Binding Students}" SelectionMode="None">
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Grid ColumnDefinitions="*,Auto" Padding="4">
									<Label Text="{Binding Name}" VerticalOptions="Center" />
									<CheckBox IsChecked="{Binding IsPresent}" />
								</Grid>
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>
					<HorizontalStackLayout Spacing="8">
						<Button Text="Save" Clicked="OnSaveClicked" />
						<Button Text="Delete" Clicked="OnDeleteClicked" />
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Frame>

			<Frame>
				<VerticalStackLayout Spacing="8">
					<Label Text="Raffle" Style="{StaticResource SubHeadline}" />
					<Button Text="Draw" Clicked="OnDrawClicked" />
					<Label Text="{Binding Result}" x:Name="ResultLabel" FontSize="24" HorizontalOptions="Center" />
					<Button Text="Assign lucky numbers for all classes" Clicked="OnAssignLuckyClicked" />
					<CollectionView ItemsSource="{Binding LuckyResults}" SelectionMode="None">
						<CollectionView.ItemTemplate>
							<DataTemplate>
								<Label Text="{Binding .}" />
							</DataTemplate>
						</CollectionView.ItemTemplate>
					</CollectionView>
				</VerticalStackLayout>
			</Frame>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>