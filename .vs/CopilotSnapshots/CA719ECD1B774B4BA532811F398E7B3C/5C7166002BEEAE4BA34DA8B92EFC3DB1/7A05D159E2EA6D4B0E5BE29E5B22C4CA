using Microsoft.Maui.Controls;
using TheSystemOfSelectingAPTA.ViewModels;

namespace TheSystemOfSelectingAPTA.Views
{
 public partial class AppView : ContentPage
 {
 private readonly AppViewModel _vm;
 public AppView()
 {
 InitializeComponent();
 _vm = new AppViewModel();
 BindingContext = _vm;
 }

 private void OnAddClicked(object sender, System.EventArgs e) => _vm?.AddStudent();
 private void OnSaveClicked(object sender, System.EventArgs e) => _vm?.SaveClass();
 private void OnDeleteClicked(object sender, System.EventArgs e) => _vm?.DeleteClass();
 private void OnNewClassClicked(object sender, System.EventArgs e) => _vm?.CreateNewClass();
 private void OnDrawClicked(object sender, System.EventArgs e) { _vm?.Draw(); DisplayAlert("Result", _vm?.Result ?? string.Empty, "OK"); }
 private void OnAssignLuckyClicked(object sender, System.EventArgs e) { _vm?.AssignLuckyNumbers(); DisplayAlert("Lucky assigned", "OK", "OK"); }
 }
}
