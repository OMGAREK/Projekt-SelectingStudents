using Microsoft.Maui.Controls;
using TheSystemOfSelectingAPTA.ViewModels;

namespace TheSystemOfSelectingAPTA.Views
{
 public partial class ClassPage : ContentPage
 {
 private readonly ClassViewModel _viewModel;
 private ClassViewModel ViewModel => _viewModel;

 public ClassPage()
 {
 InitializeComponent();
 _viewModel = new ClassViewModel();
 BindingContext = _viewModel;
 }

 private void OnAddClicked(object sender, System.EventArgs e)
 {
 ViewModel?.AddStudent();
 }

 private void OnSaveClicked(object sender, System.EventArgs e)
 {
 ViewModel?.SaveClass();
 }

 private void OnDeleteClicked(object sender, System.EventArgs e)
 {
 ViewModel?.DeleteClass();
 }

 private void OnNewClassClicked(object sender, System.EventArgs e)
 {
 ViewModel?.CreateNewClass();
 }
 }
}
