<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 xmlns:vm="clr-namespace:TheSystemOfSelectingAPTA.ViewModels"
 x:Class="TheSystemOfSelectingAPTA.Views.RafflePage"
 Title="Raffle">

    <VerticalStackLayout Padding="20" Spacing="12">
        <HorizontalStackLayout>
            <Button Text="Back" Clicked="OnBackClicked" />
            <Label Text="Raffle" Style="{StaticResource Headline}" HorizontalOptions="CenterAndExpand" />
        </HorizontalStackLayout>

        <Picker x:Name="ClassPicker" Title="Select Class" ItemsSource="{Binding Classes}" ItemDisplayBinding="{Binding ClassName}" SelectedItem="{Binding SelectedClass}" />
        <Button Text="Draw" Clicked="OnDrawClicked" />
        <Label x:Name="ResultLabel" Text="{Binding Result}" FontSize="24" HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="Gray" />
        <Button Text="Assign lucky numbers for all classes" Clicked="OnAssignLuckyClicked" />
        <CollectionView ItemsSource="{Binding LuckyResults}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>