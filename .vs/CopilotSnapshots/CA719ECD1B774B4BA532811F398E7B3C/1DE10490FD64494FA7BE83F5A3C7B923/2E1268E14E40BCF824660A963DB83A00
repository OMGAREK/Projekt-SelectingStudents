using System;
using System.Collections.ObjectModel;
using System.Collections.Generic;
using System.Linq;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using TheSystemOfSelectingAPTA.Models;

namespace TheSystemOfSelectingAPTA.ViewModels
{
    public class ClassViewModel : INotifyPropertyChanged
    {
        private readonly ClassService _service = new ClassService();

        private ObservableCollection<StudentViewModel> _students = new ObservableCollection<StudentViewModel>();
        public ObservableCollection<StudentViewModel> Students
        {
            get => _students;
            set { if (_students != value) { _students = value; OnPropertyChanged(); } }
        }

        private List<ClassModel> _classes = new List<ClassModel>();
        public List<ClassModel> Classes
        {
            get => _classes;
            set { if (_classes != value) { _classes = value; OnPropertyChanged(); } }
        }

        private ClassModel _selectedClass;
        public ClassModel SelectedClass
        {
            get => _selectedClass;
            set
            {
                if (_selectedClass == value) return;
                _selectedClass = value;
                OnPropertyChanged();
                LoadSelectedClass();
            }
        }

        private string _newStudentName;
        public string NewStudentName
        {
            get => _newStudentName;
            set { if (_newStudentName != value) { _newStudentName = value; OnPropertyChanged(); } }
        }

        private string _newClassName;
        public string NewClassName
        {
            get => _newClassName;
            set { if (_newClassName != value) { _newClassName = value; OnPropertyChanged(); } }
        }

        public ClassViewModel()
        {
            LoadClasses();
        }

        private void LoadClasses()
        {
            List<string> files = new List<string>(_service.GetClassFiles());
            List<ClassModel> models = new List<ClassModel>();
            foreach (string f in files)
            {
                ClassModel cm = new ClassModel { Name = f };
                cm.Students = _service.LoadClass(f);
                models.Add(cm);
            }
            Classes = models;
            if (Classes.Count > 0)
            {
                SelectedClass = Classes[0];
            }
        }

        private void LoadSelectedClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            Students.Clear();
            foreach (Student s in SelectedClass.Students)
            {
                Students.Add(new StudentViewModel(s));
            }
        }

        public void AddStudent()
        {
            if (string.IsNullOrWhiteSpace(NewStudentName)) return;
            Student model = new Student { Name = NewStudentName };
            Students.Add(new StudentViewModel(model));
            SelectedClass.Students.Add(model);
            NewStudentName = string.Empty;
        }

        public void SaveClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            List<Student> toSave = new List<Student>();
            foreach (StudentViewModel svm in Students)
            {
                toSave.Add(svm.Model);
            }
            _service.SaveClass(SelectedClass.Name, toSave);
        }

        public void DeleteClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            _service.DeleteClass(SelectedClass.Name);
            LoadClasses();
        }

        public void CreateNewClass()
        {
            if (string.IsNullOrWhiteSpace(NewClassName)) return;
            string name = NewClassName.Trim();
            _service.SaveClass(name, new List<Student>());
            LoadClasses();
            foreach (ClassModel c in Classes)
            {
                if (c.Name == name)
                {
                    SelectedClass = c;
                    break;
                }
            }
            NewClassName = string.Empty;
        }

        public event PropertyChangedEventHandler PropertyChanged;
        protected void OnPropertyChanged([CallerMemberName] string propertyName = "")
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(propertyName));
            }
        }
    }
}}