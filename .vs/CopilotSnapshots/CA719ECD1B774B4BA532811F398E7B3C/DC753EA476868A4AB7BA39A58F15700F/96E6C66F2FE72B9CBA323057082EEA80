using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Linq;
using System.Runtime.CompilerServices;
using TheSystemOfSelectingAPTA.Models;

namespace TheSystemOfSelectingAPTA.ViewModels
{
    public class PickerViewModel : INotifyPropertyChanged
    {
        private readonly PickerModel _model = new PickerModel();
        private readonly Random _rng = new Random();

        private ObservableCollection<PickerModel.PickerStudent> _students = new ObservableCollection<PickerModel.PickerStudent>();
        public ObservableCollection<PickerModel.PickerStudent> Students
        {
            get => _students;
            set { if (_students != value) { _students = value; OnPropertyChanged(); } }
        }

        private List<PickerModel.PickerClass> _classes = new List<PickerModel.PickerClass>();
        public List<PickerModel.PickerClass> Classes
        {
            get => _classes;
            set { if (_classes != value) { _classes = value; OnPropertyChanged(); } }
        }

        private PickerModel.PickerClass? _selectedClass = null;
        public PickerModel.PickerClass? SelectedClass
        {
            get => _selectedClass;
            set
            {
                if (_selectedClass == value) return;
                _selectedClass = value;
                OnPropertyChanged();
                LoadSelectedClass();
            }
        }

        private string _newStudentName = string.Empty;
        public string NewStudentName
        {
            get => _newStudentName;
            set { if (_newStudentName != value) { _newStudentName = value; OnPropertyChanged(); } }
        }

        private string _newClassName = string.Empty;
        public string NewClassName
        {
            get => _newClassName;
            set { if (_newClassName != value) { _newClassName = value; OnPropertyChanged(); } }
        }

        private string _result = string.Empty;
        public string Result
        {
            get => _result;
            set { if (_result != value) { _result = value; OnPropertyChanged(); } }
        }

        private ObservableCollection<string> _luckyResults = new ObservableCollection<string>();
        public ObservableCollection<string> LuckyResults
        {
            get => _luckyResults;
            set { if (_luckyResults != value) { _luckyResults = value; OnPropertyChanged(); } }
        }

        private int? _globalLuckyNumber;
        public int? GlobalLuckyNumber
        {
            get => _globalLuckyNumber;
            set { if (_globalLuckyNumber != value) { _globalLuckyNumber = value; OnPropertyChanged(); } }
        }

        public PickerViewModel()
        {
            LoadClassesFromModel();
        }

        private void LoadClassesFromModel()
        {
            List<string> files = new List<string>(_model.GetClassFiles());
            List<PickerModel.PickerClass> models = new List<PickerModel.PickerClass>();
            foreach (string f in files)
            {
                PickerModel.PickerClass cm = new PickerModel.PickerClass { Name = f };
                cm.Students = _model.LoadClass(f);
                models.Add(cm);
            }
            Classes = models;
            if (Classes.Count > 0)
            {
                SelectedClass = Classes[0];
            }
        }

        private void LoadSelectedClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            Students.Clear();
            foreach (PickerModel.PickerStudent s in SelectedClass.Students)
            {
                Students.Add(s);
            }
        }

        public void AddStudent()
        {
            if (string.IsNullOrWhiteSpace(NewStudentName)) return;
            PickerModel.PickerStudent model = new PickerModel.PickerStudent { Name = NewStudentName };
            Students.Add(model);
            SelectedClass?.Students.Add(model);
            NewStudentName = string.Empty;
        }

        public void SaveClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            _model.SaveClass(SelectedClass.Name, SelectedClass.Students);
        }

        public void DeleteClass()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;
            _model.DeleteClass(SelectedClass.Name);
            LoadClassesFromModel();
        }

        public void CreateNewClass()
        {
            if (string.IsNullOrWhiteSpace(NewClassName)) return;
            string name = NewClassName.Trim();
            _model.SaveClass(name, new List<PickerModel.PickerStudent>());
            LoadClassesFromModel();
            foreach (PickerModel.PickerClass c in Classes)
            {
                if (c.Name == name)
                {
                    SelectedClass = c;
                    break;
                }
            }
            NewClassName = string.Empty;
        }

        public void Draw()
        {
            if (SelectedClass == null || string.IsNullOrEmpty(SelectedClass.Name)) return;

            HashSet<string> luckyNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            if (GlobalLuckyNumber.HasValue)
            {
                int g = GlobalLuckyNumber.Value;
                foreach (PickerModel.PickerClass cm in Classes)
                {
                    if (g >= 1 && g <= cm.Students.Count)
                    {
                        PickerModel.PickerStudent s = cm.Students[g - 1];
                        if (!string.IsNullOrWhiteSpace(s.Name))
                        {
                            luckyNames.Add(s.Name.Trim());
                        }
                    }
                }
            }

            List<PickerModel.PickerStudent> eligible = SelectedClass.Students.Where(s => s.IsPresent && !luckyNames.Contains(s.Name)).ToList();
            if (eligible.Count == 0)
            {
                List<PickerModel.PickerStudent> presentOnly = SelectedClass.Students.Where(s => s.IsPresent).ToList();
                if (presentOnly.Count == 0)
                {
                    Result = "No students available";
                    return;
                }
                int idxFallback = _rng.Next(presentOnly.Count);
                Result = presentOnly[idxFallback].Name;
                return;
            }

            int idx = _rng.Next(eligible.Count);
            Result = eligible[idx].Name;
        }

        public void AssignLuckyNumbers()
        {
            LuckyResults.Clear();
            int max = 0;
            foreach (PickerModel.PickerClass cm in Classes)
            {
                if (cm.Students.Count > max) max = cm.Students.Count;
            }
            if (max == 0)
            {
                LuckyResults.Add("No students in any class");
                GlobalLuckyNumber = null;
                OnPropertyChanged(nameof(LuckyResults));
                return;
            }

            int pick = _rng.Next(1, max + 1);
            GlobalLuckyNumber = pick;

            foreach (PickerModel.PickerClass cm in Classes)
            {
                if (cm.Students.Count < pick)
                {
                    LuckyResults.Add($"{cm.Name}: no {pick}th student");
                    continue;
                }
                PickerModel.PickerStudent chosen = cm.Students[pick - 1];
                string status = chosen.IsPresent ? chosen.Name : "(absent)";
                LuckyResults.Add($"{cm.Name}: #{pick} -> {status}");
            }

            OnPropertyChanged(nameof(LuckyResults));
        }

        public event PropertyChangedEventHandler? PropertyChanged;
        protected void OnPropertyChanged([CallerMemberName] string propertyName = "")
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(propertyName));
        }
    }
}